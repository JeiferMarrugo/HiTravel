{
  "name": "hitravelweb",
  "version": "1.0.0",
  "description": "Sitio web de HI TRAVEL construido con Next.js.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:init": "node scripts/init-db.mjs",
    "db:status": "node scripts/db-status.mjs",
    "db:sync": "node scripts/init-db.mjs && node scripts/seed-admin.mjs && node scripts/seed-whatsapp-config.mjs && node scripts/seed-site-content.mjs && node scripts/seed-promotions.mjs",
    "db:seed": "node scripts/seed-admin.mjs",
    "db:seed-whatsapp": "node scripts/seed-whatsapp-config.mjs",
    "db:seed-catalog": "node scripts/seed-catalog.mjs",
    "db:seed-promotions": "node scripts/seed-promotions.mjs",
    "db:remove-demo-catalog": "node scripts/remove-demo-catalog.mjs",
    "db:clear-bookings": "node scripts/clear-bookings.mjs",
    "openwa:watchdog": "node scripts/openwa-watchdog.mjs",
    "docker:prepare": "node scripts/docker-prepare.mjs",
    "docker:db": "docker compose --env-file .env.docker up -d postgres openwa-api",
    "docker:up": "npm run docker:prepare && docker compose --env-file .env.docker up -d --build",
    "docker:up:fast": "docker compose --env-file .env.docker up -d",
    "docker:down": "docker compose down",
    "dev:stack": "npm run docker:db && npm run dev",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "docker:openwa:clean-locks": "docker exec hitravel-openwa sh -c \"find /app/data/sessions \\\\( -name SingletonLock -o -name SingletonCookie -o -name SingletonSocket \\\\) -delete 2>/dev/null || true\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "libphonenumber-js": "^1.13.4",
    "next": "^16.2.6",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-phone-number-input": "^3.4.17",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3"
  }
}
