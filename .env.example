# Copia este archivo a .env.local y reemplaza los valores de ejemplo.

# PostgreSQL — usa el Postgres de Docker (npm run docker:db) en el puerto 5433.
# Si tienes otro PostgreSQL instalado en Windows en el mismo puerto, local y Docker
# verán datos distintos (ej. 80.000 en Docker vs 315.000 en local). Comprueba con: npm run db:status
DATABASE_URL=postgresql://postgres:your_password@localhost:5433/base_datos_name

# Sesión admin (mínimo 32 caracteres)
SESSION_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# Usuario inicial (solo para npm run db:seed)
ADMIN_SEED_EMAIL=admin@hitravel.com
ADMIN_SEED_PASSWORD=change_me_secure_password
ADMIN_SEED_NAME=Administrador HI TRAVEL

# OpenWA
OPENWA_BASE_URL=http://localhost:2785/api
OPENWA_API_KEY=owa_k1_your_api_key_here
OPENWA_SESSION_ID=00000000-0000-0000-0000-000000000000
OPENWA_TARGET_PHONE=573001234567
OPENWA_DEFAULT_COUNTRY_CODE=57
OPENWA_WEBHOOK_SECRET=your_webhook_secret_here

# Auto-inicio de sesión WhatsApp (watchdog)
OPENWA_AUTO_START=true
OPENWA_WATCHDOG_SECRET=replace_with_a_long_random_secret

# URL pública (enlaces de reseña en WhatsApp y documentación API)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Documentación interactiva: http://localhost:3000/docs
# Especificación OpenAPI JSON: http://localhost:3000/api/openapi

# --- Docker (opcional) ---
# Copia .env.docker.example a .env.docker
#
# Desarrollo en tiempo real (recomendado):
#   npm run docker:db    (solo Postgres + OpenWA)
#   npm run dev          (sitio en http://localhost:3000 con cambios al instante)
#   npm run db:status    (ver precios y promociones de LA base que usa .env.local)
#   .env.local: misma POSTGRES_PASSWORD que .env.docker y puerto 5433
#
# Stack completo empaquetado (producción local, sin hot-reload):
#   npm run docker:up
#   → Reconstruye la imagen; hace falta tras cambiar código.
#   npm run docker:up:fast   → solo reinicia contenedores, sin rebuild
#
# Sitio Docker: http://localhost:3000 | OpenWA: http://localhost:2785/api
