# Copia este archivo a .env.docker y ajusta los valores.

POSTGRES_PASSWORD=change_me_secure_password

# Auth admin HiTravel
SESSION_SECRET=replace_with_a_long_random_secret_at_least_32_chars
ADMIN_SEED_EMAIL=admin@hitravel.com
ADMIN_SEED_PASSWORD=AdminHiTravel2026!
ADMIN_SEED_NAME=Administrador HI TRAVEL

# OpenWA — tras el primer arranque, copia la clave desde:
#   docker exec hitravel-openwa cat /app/data/.api-key
# o busca "API Key" en: docker logs hitravel-openwa
OPENWA_API_KEY=owa_k1_replace_with_your_openwa_master_key
OPENWA_SESSION_ID=
OPENWA_TARGET_PHONE=573001234567
OPENWA_DEFAULT_COUNTRY_CODE=57
OPENWA_WEBHOOK_SECRET=replace_with_webhook_secret

# Watchdog WhatsApp
OPENWA_AUTO_START=true
OPENWA_WATCHDOG_SECRET=replace_with_watchdog_secret

# URL pública del sitio (para acceder desde tu navegador)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
